# ─────────────────────────────────────────────────────────────
# EduConnect Backend — Environment Variables
# Copy this file to .env and fill in the values.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────

# ── Server ────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development
APP_VERSION=1.0.0
COMMIT_SHA=local

# ── Database (PostgreSQL — Supabase or local) ─────────────────
# Get this from Supabase > Project Settings > Database > Connection String
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT.supabase.co:5432/postgres


# ── Firebase Admin SDK (Service Account) ──────────────────────
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
FIREBASE_STORAGE_BUCKET=

# ── Razorpay ──────────────────────────────────────────────────
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# ── Security ──────────────────────────────────────────────────
# CORS (comma-separated origins)
# CORS_ORIGINS=https://app.educonnect.in,https://admin.educonnect.in

# Machine-to-machine API keys (format: key:name,key:name)
# API_KEYS=your-api-key:admin-cli

# ── Monitoring ────────────────────────────────────────────────
# Bearer token for /metrics endpoint (optional)
# METRICS_AUTH_TOKEN=

# Log level: fatal, error, warn, info, debug, trace
LOG_LEVEL=info

# ── Rate Limiting ─────────────────────────────────────────────
RATE_LIMIT_MAX=100
RATE_LIMIT_AUTH_MAX=20

# ── Email (optional) ─────────────────────────────────────────
# SENDGRID_API_KEY=
# EMAIL_FROM=noreply@educonnect.app
# EMAIL_FROM_NAME=EduConnect

# ── Error Tracking (optional) ────────────────────────────────
# SENTRY_DSN=

